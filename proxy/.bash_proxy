# 流量转发（在 `no_proxy` 中配置各家镜像域名以避免镜像源走代理）
# no_proxy 匹配语义：curl/wget/requests 等按"主机名后缀"匹配，所以
# `mirrors.ustc.edu.cn` 会自动覆盖 `pypi.mirrors.ustc.edu.cn`；但
# `pypi.tuna.tsinghua.edu.cn` 不以 `mirrors.tuna.tsinghua.edu.cn` 结尾，
# 这种非对称命名的子域必须单独列。
# 云厂商镜像（仅在对应云上的机器才解析得到/有意义）：
# - mirrors.tencentyun.com         腾讯云
# - repo.huaweicloud.com           华为云
# - mirrors.aliyun.com             阿里云
# - mirrors.volces.com             火山云（公网）
# - mirrors.ivolces.com            火山云（内网）
# - mirrors.baidubce.com           百度云
# 教育网公开镜像（公网通用，任何机器都该直连）：
# - mirrors.pku.edu.cn             北大
# - mirrors.tuna.tsinghua.edu.cn   清华 TUNA（系统包/conda 等）
# - pypi.tuna.tsinghua.edu.cn      清华 PyPI（独立子域，需单独列）
# - mirrors.ustc.edu.cn            中科大（自动覆盖 pypi.mirrors.ustc.edu.cn）
# - mirror.sjtu.edu.cn             上海交大（注意是单数 mirror）
# AI 模型镜像（国内服务器拉权重/数据集高频）：
# - hf-mirror.com                  HuggingFace 国内镜像
# - modelscope.cn                  阿里达摩院魔搭
# 工具链 registry 镜像：
# - registry.npmmirror.com         npm（原淘宝源）
# - goproxy.cn                     Go modules
export HTTP_PROXY="http://127.0.0.1:7890"
export HTTPS_PROXY="http://127.0.0.1:7890"
export ALL_PROXY="socks5://127.0.0.1:7890"
export http_proxy="http://127.0.0.1:7890"
export https_proxy="http://127.0.0.1:7890"
export all_proxy="socks5://127.0.0.1:7890"
export NO_PROXY="localhost,127.0.0.1,::1,mirrors.tencentyun.com,repo.huaweicloud.com,mirrors.aliyun.com,mirrors.volces.com,mirrors.ivolces.com,mirrors.baidubce.com,mirrors.pku.edu.cn,mirrors.tuna.tsinghua.edu.cn,pypi.tuna.tsinghua.edu.cn,mirrors.ustc.edu.cn,mirror.sjtu.edu.cn,hf-mirror.com,modelscope.cn,registry.npmmirror.com,goproxy.cn"
export no_proxy="localhost,127.0.0.1,::1,mirrors.tencentyun.com,repo.huaweicloud.com,mirrors.aliyun.com,mirrors.volces.com,mirrors.ivolces.com,mirrors.baidubce.com,mirrors.pku.edu.cn,mirrors.tuna.tsinghua.edu.cn,pypi.tuna.tsinghua.edu.cn,mirrors.ustc.edu.cn,mirror.sjtu.edu.cn,hf-mirror.com,modelscope.cn,registry.npmmirror.com,goproxy.cn"
